# ============================================================
# play4fun 环境变量模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
#
# ⚠️ .env 文件绝不提交到 Git！
# ============================================================

# JWT 签名密钥（本地开发）
# 生产环境用: wrangler secret put JWT_SECRET
JWT_SECRET=dev-secret-change-me

# 环境标识
ENVIRONMENT=development
